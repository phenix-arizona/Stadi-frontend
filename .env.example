# Stadi Frontend — Environment Variables
# Copy this file to .env and fill in your values

# Local dev: http://localhost:4000/api
# Vercel:    https://your-backend-project.vercel.app/api
VITE_API_URL=http://localhost:4000/api

# Local dev: http://localhost:5173
# Vercel:    https://your-frontend-project.vercel.app
VITE_APP_URL=http://localhost:5173

# AI chat now uses the backend `/api/ai/chat` endpoint.
# Configure `ANTHROPIC_API_KEY` in the backend environment instead of exposing it here.
